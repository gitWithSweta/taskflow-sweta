# Copy to `.env` at the repo root for Docker Compose. Never commit `.env` (gitignored).
# Replace JWT_SECRET and POSTGRES_PASSWORD for anything beyond local review.

POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

JWT_SECRET=taskflow-dev-jwt-secret-change-me-for-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

WEB_PORT=3000
TZ=UTC
