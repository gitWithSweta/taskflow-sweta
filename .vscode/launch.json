{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API (TaskFlow server)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "buildFlags": ["-gcflags", "all=-N -l"],
      "console": "integratedTerminal"
    }
  ]
}
